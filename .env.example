# IBCB Investment — 環境變量
# 複製此文件為 .env 並填入真實值

PORT=3000
NODE_ENV=production

# Session 金鑰 — 用以下命令生成: openssl rand -hex 32
SESSION_SECRET=replace-with-output-of-openssl-rand-hex-32

# 可選：SMTP 電郵設定（不設則只 log 不發送）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=admin@ibcgroup.com.hk
SMTP_PASS=your-app-password
SMTP_FROM=noreply@ibcgroup.com.hk